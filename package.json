{
  "name": "procurement-plan-system",
  "version": "1.0.0",
  "description": "Procurement Plan Management System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.dmwfad.procurement",
    "productName": "Procurement Plan System",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "procurement",
    "planning",
    "management"
  ],
  "author": "DMW FAD",
  "license": "MIT",
  "devDependencies": {
    "adm-zip": "^0.5.16",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  },
  "dependencies": {
    "compromise": "^14.15.0",
    "socket.io-client": "^4.8.3",
    "xlsx": "^0.18.5"
  }
}
